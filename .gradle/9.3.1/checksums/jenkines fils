pipeline {
    agent any
    tools { 
        maven 'Maven3' 
        jdk 'JDK17' 
    }
    stages {
        stage('Build') {
            steps {
                bat 'mvn -Dmaven.test.failure.ignore=true clean package'
            }
        }
        stage('Docker Build') {
            steps {
                bat 'docker build -t bnuthana20-prog/my-jenkins-app:${BUILD_NUMBER} .'
            }
        }
    }
}